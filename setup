#!/usr/bin/env bash
# gen-ai-skills setup — first-time installation for Claude Code, Cursor, Codex, etc.
# Idempotent: safe to run multiple times.
set -euo pipefail

# ─── Colors (degrade gracefully) ─────────────────────────────
if [ -t 1 ] && command -v tput &>/dev/null && [ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]; then
  GREEN=$(tput setaf 2) YELLOW=$(tput setaf 3) RED=$(tput setaf 1) BOLD=$(tput bold) RESET=$(tput sgr0)
else
  GREEN="" YELLOW="" RED="" BOLD="" RESET=""
fi

ok()   { echo "${GREEN}✓${RESET} $1"; }
warn() { echo "${YELLOW}!${RESET} $1"; }
err()  { echo "${RED}✗${RESET} $1"; }
info() { echo "${BOLD}→${RESET} $1"; }

# ─── Locate repo root ────────────────────────────────────────
SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"
if [ ! -f "$SKILL_DIR/VERSION" ]; then
  err "Cannot find VERSION — run this script from the PicsArt/gen-ai-skills repo root."
  exit 1
fi

VERSION="$(tr -d '[:space:]' < "$SKILL_DIR/VERSION")"
echo
echo "${BOLD}Picsart Gen-AI Skills setup — v$VERSION${RESET}"
echo

# ─── Parse flags ────────────────────────────────────────────
HOST_OVERRIDE=""
while [ $# -gt 0 ]; do
  case "$1" in
    --host)
      shift
      [ $# -eq 0 ] && { err "--host requires a value: claude | cursor | codex"; exit 1; }
      HOST_OVERRIDE="$1"
      shift
      ;;
    --host=*)
      HOST_OVERRIDE="${1#--host=}"
      shift
      ;;
    --help|-h)
      cat <<EOF
Usage: ./setup [options]

Options:
  --host <agent>   Force install path for: claude, cursor, codex
                   (auto-detected if omitted)
  --help           Show this message

Idempotent: safe to run multiple times.
EOF
      exit 0
      ;;
    *)
      warn "Unknown flag: $1"
      shift
      ;;
  esac
done

# ─── Detect agent host ──────────────────────────────────────
detect_host() {
  if [ -n "$HOST_OVERRIDE" ]; then
    echo "$HOST_OVERRIDE"
    return
  fi
  if [ -d "$HOME/.claude" ];  then echo "claude"; return; fi
  if [ -d "$HOME/.cursor" ];  then echo "cursor"; return; fi
  if [ -d "$HOME/.codex" ];   then echo "codex";  return; fi
  echo "unknown"
}

HOST="$(detect_host)"
case "$HOST" in
  claude)  TARGET_DIR="$HOME/.claude/skills" ;;
  cursor)  TARGET_DIR="$HOME/.cursor/plugins" ;;
  codex)   TARGET_DIR="$HOME/.codex/plugins" ;;
  unknown)
    warn "Could not auto-detect agent host."
    info "Re-run with --host <claude|cursor|codex>, or clone the repo manually into your agent's skills directory."
    exit 1
    ;;
  *)
    err "Unknown host: $HOST"
    exit 1
    ;;
esac

# ─── Discover skills (any subdir of skills/ with SKILL.md) ──
SKILLS_ROOT="$SKILL_DIR/skills"
if [ ! -d "$SKILLS_ROOT" ]; then
  err "Cannot find skills/ directory at $SKILLS_ROOT"
  exit 1
fi

SKILLS=()
for dir in "$SKILLS_ROOT"/*/; do
  [ -d "$dir" ] || continue
  name="$(basename "$dir")"
  case "$name" in
    .*) continue ;;
  esac
  if [ -f "$dir/SKILL.md" ]; then
    SKILLS+=("$name")
  fi
done

if [ ${#SKILLS[@]} -eq 0 ]; then
  warn "No skills found (no directory under skills/ contains a SKILL.md)."
  exit 0
fi

ok "Detected host: $HOST"
ok "Target install path: $TARGET_DIR/<skill-name>"
ok "Skills to install: ${SKILLS[*]}"
echo

# ─── Install skills ─────────────────────────────────────────
mkdir -p "$TARGET_DIR"
for skill in "${SKILLS[@]}"; do
  src="$SKILLS_ROOT/$skill"
  dst="$TARGET_DIR/$skill"
  if [ -L "$dst" ]; then
    if [ "$(readlink "$dst")" = "$src" ]; then
      ok "$skill already symlinked"
    else
      info "$skill: replacing stale symlink"
      rm "$dst"
      ln -s "$src" "$dst"
      ok "$skill symlinked"
    fi
  elif [ -e "$dst" ]; then
    warn "$dst exists but is not a symlink to $src — leaving alone."
  else
    ln -s "$src" "$dst"
    ok "$skill symlinked"
  fi
done
echo

# ─── Verify ─────────────────────────────────────────────────
info "Verifying install…"
fail=0
for skill in "${SKILLS[@]}"; do
  if [ -f "$TARGET_DIR/$skill/SKILL.md" ]; then
    ok "$skill present"
  else
    err "$skill missing at $TARGET_DIR/$skill/SKILL.md"
    fail=1
  fi
done
echo

if [ "$fail" -eq 0 ]; then
  echo "${GREEN}${BOLD}Done.${RESET}"
else
  err "Setup completed with errors. Review the messages above."
  exit 1
fi
